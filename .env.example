# ============================================
# TripJoy API - Environment Configuration
# ============================================
# Copy this file to .env and update with your values
# DO NOT commit .env to git!

# --- Docker Compose Config ---
COMPOSE_PROJECT_NAME=tripjoy

# --- Server Config ---
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# --- Database Config (PostgreSQL + PostGIS) ---
POSTGRES_VERSION=17-3.5
DB_NAME=tripjoy
DB_USERNAME=postgres
DB_PASSWORD=your_secure_password_here
DB_HOST=localhost
DB_PORT=5432

# --- Redis Config ---
REDIS_VERSION=7.2-alpine
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# --- Socket.IO Config ---
SOCKET_HOST=localhost
SOCKET_PORT=8085

# --- Security & JWT (Keep Secret!) ---
# Generate new key: openssl rand -hex 32
JWT_SIGNER_KEY=generate_your_own_jwt_signer_key_here
JWT_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=360000

# --- Swagger UI ---
SWAGGER_SERVER_URL=http://localhost:8080
SWAGGER_SERVER_DESCRIPTION=Local Development Environment
