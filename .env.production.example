# ============================================================
# .env.production.example — Production Environment Template
#
# CÁCH DÙNG:
#   1. Copy file này thành .env (ĐỪNG commit file .env thật lên git!)
#   2. Điền tất cả các giá trị
#   3. Base64 encode toàn bộ file để lưu vào GitHub Secret ENV_PROD:
#      cat .env | base64 -w 0
#   4. Paste output vào GitHub → Settings → Secrets → ENV_PROD
#
# ============================================================

# --- Docker Compose ---
COMPOSE_PROJECT_NAME=tripjoy

# --- Spring Boot ---
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=prod

# --- Database (PostgreSQL + PostGIS) ---
POSTGRES_VERSION=17-3.5
DB_NAME=tripjoy_prod
DB_USERNAME=tripjoy_user
DB_PASSWORD=CHANGE_ME_use_strong_password_min_20_chars

# --- Redis ---
REDIS_VERSION=7.2-alpine
REDIS_PASSWORD=CHANGE_ME_use_strong_redis_password

# --- Socket.IO ---
SOCKET_HOST=0.0.0.0
SOCKET_PORT=8085

# --- JWT (Generate bằng: openssl rand -hex 32) ---
JWT_SIGNER_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=360000

# --- Swagger ---
SWAGGER_SERVER_URL=http://YOUR_EC2_PUBLIC_IP:8080
SWAGGER_SERVER_DESCRIPTION=Production API

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# --- External Services ---
GOOGLE_PLACES_API_KEY=your_google_places_api_key
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_API_KEY=your_internal_ai_service_key

# --- Grafana ---
# Đổi password mặc định ngay sau khi deploy lần đầu!
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_grafana_admin_password

# --- Docker Hub (dùng trong docker-compose.prod.yml) ---
# Được inject tự động bởi GitHub Actions — không cần set thủ công trên EC2
# DOCKERHUB_USERNAME=your_dockerhub_username
# IMAGE_TAG=latest
