# ============================================================
# .env.staging.example — Staging Environment Template
#
# CÁCH DÙNG:
#   1. Copy file này thành .env
#   2. Điền các giá trị  
#   3. Base64 encode để lưu vào GitHub Secret ENV_STAGING:
#      cat .env | base64 -w 0
# ============================================================

# --- Docker Compose ---
COMPOSE_PROJECT_NAME=tripjoy-staging
API_PUBLISHED_PORT=8082

# --- AI Service ---
# Gọi trực tiếp qua Docker network ảo thay vì IP public (bảo mật & không độ trễ)
AI_SERVICE_URL=http://tripjoy-ai-service:8000

# --- Spring Boot ---
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=prod

# --- Database ---
POSTGRES_VERSION=17-3.5
DB_NAME=tripjoy_staging
DB_USERNAME=tripjoy_staging_user
DB_PASSWORD=CHANGE_ME_staging_password

# --- Redis ---
REDIS_VERSION=7.2-alpine
REDIS_PASSWORD=CHANGE_ME_staging_redis_password

# --- Socket.IO ---
SOCKET_HOST=0.0.0.0
SOCKET_PORT=8085

# --- JWT ---
JWT_SIGNER_KEY=CHANGE_ME_staging_jwt_key_openssl_rand_hex_32
JWT_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=360000

# --- Swagger ---
SWAGGER_SERVER_URL=http://YOUR_STAGING_EC2_IP:8080
SWAGGER_SERVER_DESCRIPTION=Staging Environment

# --- Cloudinary (có thể dùng account test riêng) ---
CLOUDINARY_CLOUD_NAME=your_staging_cloud_name
CLOUDINARY_API_KEY=your_staging_cloudinary_api_key
CLOUDINARY_API_SECRET=your_staging_cloudinary_api_secret

# --- External Services ---
GOOGLE_PLACES_API_KEY=your_google_places_api_key
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_API_KEY=staging_internal_key

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_staging_grafana_password
